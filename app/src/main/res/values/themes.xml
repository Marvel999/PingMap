<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.PingMap" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- Shown on cold start; switches to Theme.PingMap when first frame is ready -->
    <style name="Theme.PingMap.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_screen_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.PingMap</item>
    </style>
</resources>